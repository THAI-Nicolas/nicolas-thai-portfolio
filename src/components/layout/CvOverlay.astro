---
import MainBouton from "../boutons/MainBouton.astro";
import SmallBouton from "../boutons/SmallBouton.astro";
import ContactBouton from "../boutons/ContactBouton.astro";
import Fleche from "../ui/Fleche.astro";

export interface Props {
  isVisible?: boolean;
  onClose?: () => void;
}

const { isVisible = false, onClose } = Astro.props;
---

<div
  class="cv-overlay opacity-0 pointer-events-none fixed inset-0 z-[60]"
  style="transition: opacity 0.3s ease-in-out;"
>
  <div class="bg-black/50 fixed inset-0 z-[70] overflow-hidden"></div>

  <div
    class="cv-container fixed inset-0 z-[80] flex items-center justify-start overflow-y-auto xl:overflow-hidden"
    id="cv-container"
  >
    <!-- Layout mobile/tablette : vertical -->
    <div class="flex flex-col xl:hidden w-full h-full py-6 px-4 gap-6">
      <!-- Bouton retour en haut à droite -->
      <div class="flex justify-end">
        <div id="cv-return-button-mobile" class="cv-return-button">
          <MainBouton type="retour" size="mobile" />
        </div>
      </div>

      <!-- CV miniature cliquable (pas de Mii 3D sur mobile/tablette : encombrement + coût de rendu) -->
      <div class="flex-shrink-0 my-auto flex items-center justify-center w-full px-4">
        <div id="cv-miniature" class="relative w-[80%] cursor-pointer transform transition-transform duration-300 hover:scale-105">
          <div class="absolute md:top-10 top-10 right-2 z-10">
            <SmallBouton type="telechargement" size="mobile" />
          </div>
          <div class="w-full">
            <picture>
              <source 
                srcset="/images/cv-nicolas-thai.avif" 
                type="image/avif" 
              />
              <source 
                srcset="/images/cv-nicolas-thai.webp" 
                type="image/webp" 
              />
              <img
                src="/images/cv-nicolas-thai.png"
                alt="CV de Nicolas THAI"
                class="w-full h-auto rounded-lg shadow-lg"
                width="600"
                height="850"
                loading="lazy"
                decoding="async"
              />
            </picture>
          </div>
        </div>
      </div>

      <!-- 4 ContactBoutons en bas -->
      <div class="flex justify-center gap-3 pb-4">
        <ContactBouton type="email" />
        <ContactBouton type="github" />
        <ContactBouton type="linkedin" />
        <ContactBouton type="instagram" />
      </div>
    </div>

    <!-- Layout laptop/desktop : horizontal
         (centré sur la bande 1280-1919, aligné à gauche calibré 1920 au-delà) -->
    <div class="hidden xl:flex items-start justify-start mx-auto 3xl:mx-0 3xl:pl-20">
      <div class="flex items-stretch gap-8 3xl:gap-12">
        <!-- Partie 1 : MainBouton retour + Boutons Contact -->
        <div
          class="flex flex-col items-center justify-between flex-shrink-0 mt-6 mb-3 ml-2 3xl:mt-8 3xl:mb-4 3xl:ml-8"
        >
          <!-- Version laptop -->
          <div id="cv-return-button-laptop" class="cv-return-button 3xl:hidden">
            <MainBouton type="retour" size="tablet" />
          </div>
          <!-- Version desktop -->
          <div id="cv-return-button-desktop" class="cv-return-button hidden 3xl:block">
            <MainBouton type="retour" size="desktop" />
          </div>
          <div class="flex flex-col items-center gap-6 3xl:gap-8">
            <ContactBouton type="email" />
            <ContactBouton type="github" />
            <ContactBouton type="linkedin" />
            <ContactBouton type="instagram" />
          </div>
        </div>

        <!-- Partie 2 : CV + SmallBouton téléchargement -->
        <div class="relative flex-shrink-0 flex items-start ml-4 3xl:ml-12">
          <div class="relative w-[460px] 3xl:w-[600px]">
            <div class="absolute top-8 right-2 3xl:top-10 3xl:right-4 z-10">
              <!-- Version laptop -->
              <div class="3xl:hidden">
                <SmallBouton type="telechargement" size="laptop" />
              </div>
              <!-- Version desktop -->
              <div class="hidden 3xl:block">
                <SmallBouton type="telechargement" size="desktop" />
              </div>
            </div>
            <div class="w-full">
              <picture>
                <source 
                  srcset="/images/cv-nicolas-thai.avif" 
                  type="image/avif" 
                />
                <source 
                  srcset="/images/cv-nicolas-thai.webp" 
                  type="image/webp" 
                />
                <img
                  src="/images/cv-nicolas-thai.png"
                  alt="CV de Nicolas THAI"
                  class="w-full h-auto rounded-lg shadow-lg"
                  width="600"
                  height="850"
                  loading="lazy"
                  decoding="async"
                />
              </picture>
            </div>
          </div>
        </div>

        <!-- Partie 3 : Socle + Mii -->
        <div
          class="relative flex-shrink-0 flex items-center justify-center ml-22 3xl:-ml-12 xl:mt-20 3xl:mt-0"
        >
          <div class="relative w-96 h-96">
            <div
              class="neon-circle-outer absolute top-[120px] left-1/2 transform -translate-x-1/2 -translate-y-1/2 3xl:top-40 3xl:left-125 3xl:transform 3xl:-translate-x-1/2 3xl:-translate-y-1/2 w-[480px] h-[480px] 3xl:w-[784px] 3xl:h-[784px]"
            >
            </div>

            <div
              class="absolute bottom-[220px] 3xl:bottom-55 3xl:left-125 left-1/2 transform -translate-x-1/2 scale-100 3xl:scale-130 flex gap-80 3xl:gap-96 items-center z-40"
            >
              <div id="fleche-gauche" class="cursor-pointer">
                <Fleche direction="gauche" size="mobile" disableTransition={true} />
              </div>
              <div id="fleche-droite" class="cursor-pointer">
                <Fleche direction="droite" size="mobile" disableTransition={true} />
              </div>
            </div>

            <div
              id="mii-container"
              class="mii-container absolute left-1/2 3xl:left-125 z-30 flex items-center justify-center w-[480px] h-[600px] 3xl:w-[800px] 3xl:h-[1000px] top-[40%] 3xl:top-1/2 transform -translate-x-1/2 -translate-y-1/2"
            >
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .cv-overlay {
    transition: opacity 0.3s ease-in-out;
  }

  .cv-container {
    scrollbar-width: thin;
  }

  .neon-circle-outer {
    background: rgba(255, 255, 255, 0.7);
    border: 10.747px solid #34beed;
    border-radius: 50%;
    /* filter: drop-shadow(0 0 32.16px rgba(52, 190, 237, 1)); */
    box-shadow: 0 0 32.16px rgba(52, 190, 237, 1);
  }

</style>

<script>
  import { OverlayManager } from '../../scripts/overlay-manager';
  
  let miiScene: any | null = null;
  let miiSceneLoading = false;
  let MiiSceneClass: any = null;
  // Cleanup des inits précédentes : initCvOverlay tourne sur DOMContentLoaded
  // ET astro:page-load, sans cela listeners et observers s'accumulent
  let cvObserver: MutationObserver | null = null;
  let cvAbortController: AbortController | null = null;

  async function loadMiiScene() {
    if (!MiiSceneClass) {
      const module = await import('../../scripts/mii-scene');
      MiiSceneClass = module.MiiScene;
    }
    return MiiSceneClass;
  }

  function setupFlecheRotation(
    fleche: HTMLElement | null,
    getScene: () => any,
    direction: 'left' | 'right',
    signal: AbortSignal
  ) {
    if (!fleche) return;

    const button = fleche.querySelector('button');
    button?.addEventListener('click', (e) => e.preventDefault(), { signal });

    // Pointer Events : unifie souris et tactile (écrans laptop tactiles)
    fleche.addEventListener('pointerdown', () => {
      import('../../scripts/audio-manager').then(({ audioManager, SoundName }) => {
        audioManager.play(SoundName.PROJECT_SELECT);
      });
      getScene()?.startRotation(direction);
    }, { signal });

    fleche.addEventListener('pointerup', () => {
      getScene()?.stopRotation();
    }, { signal });

    fleche.addEventListener('pointercancel', () => {
      getScene()?.stopRotation();
    }, { signal });

    fleche.addEventListener('pointerleave', () => {
      getScene()?.stopRotation();
    }, { signal });
  }

  function initCvOverlay() {
    // Nettoyer l'init précédente avant d'en refaire une
    cvAbortController?.abort();
    cvAbortController = new AbortController();
    const signal = cvAbortController.signal;
    cvObserver?.disconnect();
    cvObserver = null;

    const overlayManager = OverlayManager.getInstance();
    const cvOverlay = document.querySelector(".cv-overlay");
    const flecheGauche = document.getElementById("fleche-gauche");
    const flecheDroite = document.getElementById("fleche-droite");

    // Setup de l'overlay avec callbacks personnalisés
    overlayManager.setupOverlay('cv', {
      onClose: () => {
        // Nettoyer la scène 3D quand l'overlay se ferme
        if (miiScene) {
          miiScene.destroy();
          miiScene = null;
        }
      }
    });

    // Observer pour détecter quand l'overlay devient visible et initialiser la scène 3D
    if (cvOverlay) {
      cvObserver = new MutationObserver(async () => {
        const isVisible = cvOverlay.classList.contains("opacity-100") &&
                         cvOverlay.classList.contains("pointer-events-auto");

        const miiContainer = document.getElementById("mii-container");

        if (isVisible) {
          // Mii 3D réservé au layout desktop (xl+) : sous 1280 on ne charge
          // même pas Three.js (le layout mobile/tablette n'a pas de Mii).
          // Verrou : l'observer se déclenche plusieurs fois pendant le
          // chargement du module → sans lui, plusieurs scènes seraient créées
          if (miiContainer && window.innerWidth >= 1280 && !miiScene && !miiSceneLoading) {
            miiSceneLoading = true;
            try {
              const MiiScene = await loadMiiScene();
              if (!miiScene && !miiContainer.querySelector('canvas')) {
                miiScene = new MiiScene(miiContainer);
              }
            } finally {
              miiSceneLoading = false;
            }
          }
        } else {
          // Détruire la scène quand l'overlay se ferme
          if (miiScene) {
            miiScene.destroy();
            miiScene = null;
          }
        }
      });

      cvObserver.observe(cvOverlay, {
        attributes: true,
        attributeFilter: ['class']
      });
    }

    // Gestion de la rotation avec les flèches desktop
    setupFlecheRotation(flecheGauche, () => miiScene, 'right', signal);
    setupFlecheRotation(flecheDroite, () => miiScene, 'left', signal);
  }

  document.addEventListener("DOMContentLoaded", initCvOverlay);
  document.addEventListener("astro:page-load", initCvOverlay);
  
  // Gestion du zoom du CV sur mobile/tablette
  // (cleanup séparé : initCvZoom tourne aussi sur DOMContentLoaded + astro:page-load)
  let cvZoomAbortController: AbortController | null = null;

  function initCvZoom() {
    cvZoomAbortController?.abort();
    cvZoomAbortController = new AbortController();

    const cvMiniature = document.getElementById('cv-miniature');

    if (cvMiniature) {
      cvMiniature.addEventListener('click', () => {
        // Zoom réservé au layout mobile/tablette (< 1280px)
        if (window.innerWidth >= 1280) return;
        if (document.getElementById('cv-zoom-overlay')) return;

        const img = cvMiniature.querySelector('img');
        if (!img) return;

        // CV plein écran, fermeture au tap n'importe où
        const zoomOverlay = document.createElement('div');
        zoomOverlay.id = 'cv-zoom-overlay';
        zoomOverlay.className = 'fixed inset-0 z-[90] bg-black/80 flex items-center justify-center p-4';

        const zoomImg = document.createElement('img');
        zoomImg.src = img.currentSrc || img.src;
        zoomImg.alt = img.alt;
        zoomImg.style.cssText = 'max-width:100%;max-height:100%;object-fit:contain;border-radius:0.5rem;box-shadow:0 25px 50px rgba(0,0,0,0.5);';

        zoomOverlay.appendChild(zoomImg);
        document.body.appendChild(zoomOverlay);

        zoomOverlay.addEventListener('click', () => zoomOverlay.remove());
      }, { signal: cvZoomAbortController.signal });
    }
  }
  
  document.addEventListener("DOMContentLoaded", initCvZoom);
  document.addEventListener("astro:page-load", initCvZoom);
  
  // Nettoyer lors du déchargement de la page
  document.addEventListener("astro:before-preparation", () => {
    if (miiScene) {
      miiScene.destroy();
      miiScene = null;
    }
  });
</script>
