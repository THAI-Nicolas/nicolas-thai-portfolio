---
import Layout from "../layouts/Layout.astro";
import { ViewTransitions } from "astro:transitions";
import ChannelProjet from "../components/ui/ChannelProjet.astro";
import Fleche from "../components/ui/Fleche.astro";
import FooterAccueil from "../components/layout/FooterAccueil.astro";
import FooterAccueilMobile from "../components/layout/FooterAccueilMobile.astro";
import CvOverlay from "../components/layout/CvOverlay.astro";
import ContactOverlay from "../components/layout/ContactOverlay.astro";
import ParametresOverlay from "../components/layout/ParametresOverlay.astro";
import PresentationOverlay from "../components/layout/PresentationOverlay.astro";
import { ProjetsService } from "../services/projets.service";

// Récupérer tous les projets visibles depuis PocketBase
const projets = await ProjetsService.getAll();
const totalChannels = 27; // 3 lignes de 9 channels

// URL de la première image de projet pour preload LCP
const firstProjectCover = projets[0] ? ProjetsService.getCoverUrl(projets[0]) : null;

// Créer un tableau de 27 channels pour desktop (ordre horizontal)
const channels = Array(totalChannels).fill(null).map((_, index) => {
  const projet = projets[index];
  if (projet) {
    return {
      isEmpty: false,
      projectCover: ProjetsService.getCoverUrl(projet),
      projectTitle: projet.titre,
      href: `/projets/${projet.slug}`
    };
  }
  return { isEmpty: true };
});

// Pour mobile : remplir colonne par colonne (vertical) avec les projets disponibles
const channelsMobile = Array(totalChannels).fill(null).map(() => ({ isEmpty: true }));
const rows = 3;
const cols = 9;

projets.forEach((projet, index) => {
  const col = Math.floor(index / rows);  // Quelle colonne (0-8)
  const row = index % rows;               // Quelle ligne dans cette colonne (0-2)
  const gridIndex = col + (row * cols);   // Position dans la grille 9×3
  
  if (gridIndex < totalChannels) {
    channelsMobile[gridIndex] = {
      isEmpty: false,
      projectCover: ProjetsService.getCoverUrl(projet),
      projectTitle: projet.titre,
      href: `/projets/${projet.slug}`
    };
  }
});
---

<Layout
  title="Nicolas THAI | Portfolio Développeur Web Junior"
  description="Bienvenue sur le portfolio de Nicolas THAI, développeur web junior français. Découvrez ses projets et ses compétences !"
  keywords="Nicolas THAI, portfolio wii, portfolio interactif, portfolio créatif, développeur web junior, développeur front-end, JavaScript, Astro, TypeScript, TailwindCSS, Three.js, UX Design, UI Design, interface Nintendo Wii, web design créatif, portfolio original, développeur Nice, France"
  ogImage="/og-home.jpg"
>
  <ViewTransitions />
  <!-- Version Desktop (LG et XL) -->
  <div class="hidden lg:block">
    <!-- Zone principale avec grille de channels -->
    <main class="relative h-dvh bg-background overflow-hidden">
      <!-- SEO: Titre principal caché visuellement mais accessible aux lecteurs d'écran -->
      <h1 class="sr-only">Nicolas THAI - Portfolio Wii | Développeur Web Front-End Créatif France</h1>
      
      <!-- Container pour le carrousel -->
      <div class="relative w-full h-full overflow-hidden">
        <!-- Section projets avec titre sémantique -->
        <section aria-label="Mes projets web">
          <h2 class="sr-only">Galerie de projets</h2>
          
          <!-- Grille unique avec tous les channels -->
          <div id="grid-anchor" class="absolute top-[38%] -translate-y-1/2" style="left: clamp(3rem, 8vw, 10rem);">
            <div
              id="carousel-grid"
              class="grid grid-cols-9 w-max transition-transform duration-800 ease-in-out ml-8"
              style="row-gap: clamp(0rem, 0.7vw, 0.7rem); column-gap: 1rem;"
              role="list"
              aria-label="Liste des projets"
            >
              {channels.map((channel, index) => (
                <ChannelProjet
                  isEmpty={channel.isEmpty}
                  projectCover={channel.isEmpty ? undefined : channel.projectCover}
                  projectTitle={channel.isEmpty ? undefined : channel.projectTitle}
                  href={channel.isEmpty ? undefined : channel.href}
                  size="desktop"
                  isPriority={index < 9}
                />
              ))}
            </div>
          </div>
        </section>

        <!-- Flèche de navigation à droite -->
        <div
          class="absolute top-1/2 -translate-y-1/2 z-30 cursor-pointer animate-[bounce-right_1.5s_infinite]"
          style="right: clamp(3rem, 6vw, 6rem);"
          id="arrow-right"
        >
          <Fleche direction="droite" size="desktop" disableTransition={true} />
        </div>

        <!-- Flèche de navigation à gauche -->
        <div
          class="absolute top-1/2 -translate-y-1/2 z-30 cursor-pointer opacity-0"
          style="left: clamp(1rem, 4vw, 6rem);"
          id="arrow-left"
        >
          <Fleche direction="gauche" size="desktop" disableTransition={true} />
        </div>
      </div>
    </main>

    <!-- Footer Desktop -->
    <footer>
      <FooterAccueil />
    </footer>
  </div>

  <!-- Version Mobile + Tablette (jusqu'à LG) -->
  <div class="lg:hidden flex flex-col min-h-dvh">
    <main class="relative bg-background overflow-hidden flex-1 flex items-center pb-32">
      <!-- Container pour le carrousel mobile -->
      <div class="relative w-full">
        <section aria-label="Mes projets web">
          <h2 class="sr-only">Galerie de projets</h2>
          
          <!-- Grille horizontale mobile - 9 colonnes × 3 lignes, défilement avec snap par colonne -->
          <div
            id="carousel-scroll-mobile"
            class="relative w-full overflow-x-auto overflow-y-hidden pl-10 pr-6 py-4 scrollbar-hide snap-x snap-mandatory scroll-pl-10"
            style="scroll-behavior: smooth;"
          >
            <div
              id="carousel-grid-mobile"
              class="grid grid-rows-3 gap-x-5 gap-y-8"
              style="width: fit-content; grid-template-columns: repeat(9, max-content);"
              role="list"
              aria-label="Liste des projets"
            >
              {channelsMobile.map((channel, index) => (
                <ChannelProjet
                  isEmpty={channel.isEmpty}
                  projectCover={channel.isEmpty ? undefined : channel.projectCover}
                  projectTitle={channel.isEmpty ? undefined : channel.projectTitle}
                  href={channel.isEmpty ? undefined : channel.href}
                  size="mobile"
                  isPriority={index < 3}
                />
              ))}
            </div>
          </div>
        </section>

        <!-- Flèche de navigation droite -->
        <div
          class="absolute right-2 top-1/2 transform -translate-y-1/2 z-30 cursor-pointer p-3"
          id="arrow-right-mobile"
          role="button"
          aria-label="Voir les projets suivants"
          tabindex="0"
        >
          <Fleche direction="droite" size="mobile" disableTransition={true} />
        </div>

        <!-- Flèche de navigation gauche -->
        <div
          class="absolute left-2 top-1/2 transform -translate-y-1/2 z-30 cursor-pointer p-3 opacity-0"
          id="arrow-left-mobile"
          role="button"
          aria-label="Voir les projets précédents"
          tabindex="0"
        >
          <Fleche direction="gauche" size="mobile" disableTransition={true} />
        </div>
      </div>
    </main>
    
    <!-- Footer mobile collé en bas -->
    <footer class="mt-auto">
      <FooterAccueilMobile />
    </footer>
  </div>

  <!-- CvOverlay -->
  <CvOverlay />

  <!-- ContactOverlay -->
  <ContactOverlay />

  <!-- ParametresOverlay -->
  <ParametresOverlay />

  <!-- PresentationOverlay -->
  <PresentationOverlay />
  
  <!-- Script carousel -->
  <script is:inline>
    function setupCarousel() {
      // Utiliser requestAnimationFrame pour attendre le prochain cycle de rendu
      requestAnimationFrame(function() {
        requestAnimationFrame(function() {
          var arrowRightContainer = document.getElementById('arrow-right');
          var arrowLeftContainer = document.getElementById('arrow-left');
          var carouselGrid = document.getElementById('carousel-grid');
          
          if (arrowRightContainer && arrowLeftContainer && carouselGrid) {
            var arrowRight = arrowRightContainer.querySelector('.fleche');
            var arrowLeft = arrowLeftContainer.querySelector('.fleche');
            
            if (!arrowRight || !arrowLeft) return;
            
            var currentPage = 1;
            arrowLeftContainer.style.opacity = '0';
            
            arrowRight.onclick = function(e) {
              e.preventDefault();
              e.stopPropagation();
              
              var firstChannel = carouselGrid.querySelector('.channel-fluid');
              if (!firstChannel) return;
              
              var channelWidth = firstChannel.getBoundingClientRect().width;
              var gridStyle = window.getComputedStyle(carouselGrid);
              var gap = parseFloat(gridStyle.columnGap) || 0;
              var shift = (channelWidth + gap) * 5.4;

              // Sous 1536px, le décalage 5.4 (calibré pour 1920) dépasse la fin
              // de la grille : le plafonner pour caler la dernière colonne
              // avec une marge à droite pour la flèche retour
              if (window.innerWidth < 1536) {
                var gridRect = carouselGrid.getBoundingClientRect();
                var maxShift = gridRect.left + gridRect.width - window.innerWidth + 100;
                shift = Math.min(shift, Math.max(0, maxShift));
              }

              carouselGrid.style.transform = 'translateX(' + (-shift) + 'px)';
              arrowRightContainer.style.opacity = '0';
              arrowLeftContainer.style.opacity = '1';
              currentPage = 2;
            };
            
            arrowLeft.onclick = function(e) {
              e.preventDefault();
              e.stopPropagation();

              carouselGrid.style.transform = 'translateX(0)';
              arrowRightContainer.style.opacity = '1';
              arrowLeftContainer.style.opacity = '0';
              currentPage = 1;
            };
          }

          // Carrousel mobile : défilement natif avec snap, flèches en scroll programmatique
          var mobileScroller = document.getElementById('carousel-scroll-mobile');
          var mobileGrid = document.getElementById('carousel-grid-mobile');
          var arrowRightMobile = document.getElementById('arrow-right-mobile');
          var arrowLeftMobile = document.getElementById('arrow-left-mobile');

          if (mobileScroller && mobileGrid && arrowRightMobile && arrowLeftMobile) {
            var mobileStep = function() {
              var card = mobileGrid.querySelector('.channel-mobile');
              if (!card) return 300;
              var gap = parseFloat(window.getComputedStyle(mobileGrid).columnGap) || 0;
              return card.getBoundingClientRect().width + gap;
            };

            var updateMobileArrows = function() {
              var maxScroll = mobileScroller.scrollWidth - mobileScroller.clientWidth;
              arrowLeftMobile.style.opacity = mobileScroller.scrollLeft > 10 ? '1' : '0';
              arrowRightMobile.style.opacity = mobileScroller.scrollLeft < maxScroll - 10 ? '1' : '0';
            };

            // Assignations (idempotentes) : le script tourne sur DOMContentLoaded ET astro:page-load
            arrowRightMobile.onclick = function() {
              mobileScroller.scrollBy({ left: mobileStep(), behavior: 'smooth' });
            };
            arrowLeftMobile.onclick = function() {
              mobileScroller.scrollBy({ left: -mobileStep(), behavior: 'smooth' });
            };

            var mobileArrowsTicking = false;
            mobileScroller.onscroll = function() {
              if (mobileArrowsTicking) return;
              mobileArrowsTicking = true;
              requestAnimationFrame(function() {
                updateMobileArrows();
                mobileArrowsTicking = false;
              });
            };

            updateMobileArrows();
          }
        });
      });
    }
    
    // Premier chargement
    window.addEventListener('DOMContentLoaded', setupCarousel);
    
    // Après navigation Astro
    document.addEventListener('astro:page-load', setupCarousel);
  </script>
</Layout>

<script>
  // Lazy load des overlays (non critiques, chargés après le rendu initial)
  function initOverlayButtons() {
    // Vérifier qu'on est sur la page d'accueil
    if (window.location.pathname !== '/') return;
    
    // Dynamic import pour réduire le bundle initial
    import('../scripts/overlay-manager').then(({ OverlayManager }) => {
      const overlayManager = OverlayManager.getInstance();
      
      // Setup tous les overlays
      overlayManager.setupOverlay('cv');
      overlayManager.setupOverlay('contact');
      overlayManager.setupOverlay('presentation');
      overlayManager.setupOverlay('parametres');
    });
  }
  
  // Charger les overlays avec requestIdleCallback pour éviter de bloquer le thread principal
  if ('requestIdleCallback' in window) {
    requestIdleCallback(initOverlayButtons);
  } else {
    // Fallback pour les navigateurs qui ne supportent pas requestIdleCallback
    setTimeout(initOverlayButtons, 1);
  }
  
  // Réinit après transition Astro
  document.addEventListener("astro:page-load", initOverlayButtons);
</script>

<style>
  @keyframes bounce-right {
    0%, 100% {
      transform: translateY(-50%) translateX(0);
    }
    50% {
      transform: translateY(-50%) translateX(10px);
    }
  }
  
  #arrow-right-mobile {
    animation: bounce-right-mobile 1.5s infinite;
  }
  
  /* Ne pas ré-appliquer translateY(-50%) ici : le centrage vertical vient déjà
     de la propriété `translate` (utilitaire -translate-y-1/2 de Tailwind v4) ;
     un translateY dans le transform de l'animation se composerait avec (→ -100%) */
  @keyframes bounce-right-mobile {
    0%, 100% {
      transform: translateX(0);
    }
    50% {
      transform: translateX(10px);
    }
  }

  /* Cacher la scrollbar tout en gardant la fonctionnalité */
  .scrollbar-hide {
    -ms-overflow-style: none;  /* IE et Edge */
    scrollbar-width: none;  /* Firefox */
  }

  .scrollbar-hide::-webkit-scrollbar {
    display: none;  /* Chrome, Safari et Opera */
  }

  /* Laptops peu hauts (≤800px) : remonter la grille pour qu'elle ne chevauche
     pas le footer fixe (33px de recouvrement mesurés à 1280×720 avec top:38%) */
  @media (min-width: 1024px) and (max-width: 1535px) and (max-height: 800px) {
    #grid-anchor {
      top: 33%;
    }
  }
</style>
