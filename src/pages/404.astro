---
import Layout from "../layouts/Layout.astro";
import LargeBouton from "../components/boutons/LargeBouton.astro";

const seoDescription = "Page introuvable - Portfolio de Nicolas THAI, Développeur Web Junior.";
---

<Layout
  title="Page introuvable | Nicolas THAI - Portfolio"
  description={seoDescription}
  keywords="404, page introuvable, portfolio, Nicolas THAI"
>
  <main class="min-h-dvh w-full bg-background flex flex-col items-center justify-center px-6 py-10 text-center">
    <h1 class="font-raleway text-6xl lg:text-8xl font-bold text-light-blue mb-6">
      404
    </h1>
    <p class="font-raleway text-xl lg:text-2xl font-semibold text-text-gray mb-4">
      Cette chaîne n'existe pas !
    </p>
    <p class="font-raleway text-base lg:text-lg text-text-gray/70 mb-12 max-w-md">
      La page que vous cherchez est introuvable ou a été déplacée.
    </p>
    <LargeBouton href="/" text="Retour à l'accueil" variant="primary" />
  </main>
</Layout>

<style>
  /* Autoriser le scroll si le contenu dépasse (le lock global est overflow:hidden) */
  html,
  body {
    overflow-y: auto !important;
    height: auto !important;
  }
</style>
